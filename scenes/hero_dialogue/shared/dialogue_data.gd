extends RefCounted
## Dialogue content for hero conversations about practicum activities.
## Each card gets a dialogue tree where the hero discusses the activity with the player.
## Trees are keyed as "day{N}_{slot_id}" (e.g., "day1_wk", "day3_ep").
##
## Node types:
##   "say"    — hero or player speaks: {type, speaker, text}
##   "choice" — player picks an option: {type, prompt, options: [{text, next}]}
##   "action" — trigger a mini-interaction: {type, action}

class_name DialogueData

# ── Hero name ────────────────────────────────────────────────────

const HERO_NAME := "Леонардо"

# ── Helper to build a say node ───────────────────────────────────

static func say(text: String, speaker: String = "hero") -> Dictionary:
	return {"type": "say", "speaker": speaker, "text": text}

static func choice(prompt: String, options: Array) -> Dictionary:
	return {"type": "choice", "prompt": prompt, "options": options}

static func action(action_id: String) -> Dictionary:
	return {"type": "action", "action": action_id}

static func opt(text: String, next: String = "") -> Dictionary:
	return {"text": text, "next": next}


# ── Get dialogue tree for a card ─────────────────────────────────

static func get_dialogue(day: int, slot_id: String) -> Array:
	var key := "day%d_%s" % [day, slot_id]
	if key in DIALOGUES:
		return DIALOGUES[key]
	# Fallback: generate a simple dialogue from the card text
	return _make_fallback(day, slot_id)


static func _make_fallback(day: int, slot_id: String) -> Array:
	var tree: SceneTree = Engine.get_main_loop() as SceneTree
	var card: Dictionary = {}
	if tree and tree.root.has_node("GameData"):
		card = tree.root.get_node("GameData").get_card(day, slot_id)
	if card.is_empty():
		return [say("Продолжаем наш путь...")]
	return [
		say("%s %s" % [card.get("emoji", ""), card.get("title", "")]),
		say(card.get("text", "")),
		choice("Что вы думаете?", [
			opt("Отличная идея!"),
			opt("Расскажи ещё"),
		]),
		say("Прекрасно! Давайте попробуем вместе."),
		action(slot_id),
		say("Замечательно! Вы сделали ещё один шаг на пути к гармонии."),
	]


